# Backend environment variables
# Copy this file to backend/.env and fill in your values

DJANGO_SECRET_KEY=django-insecure-replace-this-in-production-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite for development)
# DATABASE_URL=postgres://user:password@localhost:5432/ai_fitness_db

# AI Integration (Anthropic Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
